{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Schema for Claude's optimization experiment decision output",
  "type": "object",
  "required": ["experiment_name", "hypothesis", "files_changed", "search_area"],
  "properties": {
    "experiment_name": {
      "type": "string",
      "minLength": 1,
      "description": "Kebab-case name for the experiment"
    },
    "hypothesis": {
      "type": "string",
      "minLength": 10,
      "description": "What optimization is being attempted and why"
    },
    "files_changed": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "List of file paths modified by this experiment"
    },
    "search_area": {
      "type": "string",
      "enum": [
        "tile-lifecycle-memory",
        "selective-precision",
        "tiled-inference-heuristics",
        "compile-path-policy",
        "tensor-layout-staging",
        "backbone-quantization",
        "mlx-memory-tuning",
        "layernorm-fusion",
        "token-routing",
        "refiner-only-tiling",
        "fused-metal-kernels",
        "sdpa-attention",
        "graph-materialization",
        "stream-pipelining",
        "weight-format",
        "operator-fusion",
        "matmul-ordering",
        "addmm-fusion",
        "dtype-cast-cleanup",
        "async-pipeline"
      ],
      "description": "Which program.md search area this targets"
    },
    "next_hypothesis": {
      "type": "string",
      "description": "Suggested next experiment for the orchestrator"
    },
    "notes": {
      "type": "string",
      "description": "Any relevant context or caveats"
    }
  },
  "additionalProperties": false
}
